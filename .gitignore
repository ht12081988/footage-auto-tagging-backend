# pyenv
#   For a library or app, you might want to share your .python-version.
#   See https://github.com/pyenv/pyenv/header-spec for more details.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may get conflicts.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be included in version control, but it depends on the project.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be included in version control, but it depends on the project.
#   pdm.lock

# PEP 582; division of dependency management and execution
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parses files before executing them, this sub-directory contains those files
.sage/

